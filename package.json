{
  "name": "aeroroute-web",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint . && prettier --check .",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "e2e": "playwright test",
    "e2e:real": "playwright test --config playwright.real.config.ts",
    "format": "prettier --write .",
    "check": "pnpm lint && pnpm typecheck && pnpm check:api && pnpm test && pnpm build && pnpm build-storybook",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build --output-dir storybook-static",
    "generate:api": "openapi-typescript ../aeroroute-contracts/openapi/aeroroute-v1.json -o src/api/generated/schema.ts",
    "check:api": "node scripts/check-generated-client.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-query": "^5.101.1",
    "@turf/great-circle": "^7.3.5",
    "lucide-react": "^1.21.0",
    "maplibre-gl": "^5.24.0",
    "openapi-fetch": "^0.17.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.80.0",
    "react-router-dom": "^7.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "latest",
    "@playwright/test": "latest",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/react-vite": "10.4.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "latest",
    "eslint-plugin-react-hooks": "latest",
    "eslint-plugin-react-refresh": "latest",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "openapi-typescript": "^7.13.0",
    "prettier": "latest",
    "prettier-plugin-classnames": "latest",
    "prettier-plugin-merge": "latest",
    "prettier-plugin-tailwindcss": "latest",
    "storybook": "10.4.6",
    "typescript": "^6.0.0",
    "typescript-eslint": "latest",
    "vite": "^8.0.0",
    "vitest": "latest"
  }
}
